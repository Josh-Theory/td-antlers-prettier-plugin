{
  "name": "td-antlers-parser",
  "version": "0.1.7",
  "description": "Extracted Antlers parser and lexer sources from Stillat's VS Code Antlers language server.",
  "author": "Josh Steele",
  "contributors": [
    "John Koster (original author)"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "out/index.js",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js",
      "default": "./out/index.js"
    }
  },
  "types": "out/index.d.ts",
  "files": [
    "out/",
    "LICENSE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Josh-Theory/antlers-parser.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run build && node --test test/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "ts-md5": "^1.2.9",
    "vscode-languageserver-types": "^3.17.5",
    "yaml": "^1.10.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^24.5.2",
    "@types/prettier": "^2.6.3",
    "@typescript-eslint/parser": "^4.29.3",
    "prettier": "^3",
    "typescript": "^5.9.2"
  }
}
